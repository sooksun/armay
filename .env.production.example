# Copy to .env.production and fill real values. .env.production is gitignored.
#
# External MariaDB on the server LAN. The `armay` database must already exist
# (CREATE DATABASE armay CHARACTER SET utf8mb4;). Prisma migrate deploy builds
# the tables on first boot.
DATABASE_URL="mysql://root:<DB_PASSWORD>@192.168.1.4:3306/armay"

# Session signing key — generate with: openssl rand -base64 48
JWT_SECRET="<GENERATE_ME>"

# Local-disk attachment dir inside the container (mounted volume). Keep as-is.
UPLOAD_DIR="/app/uploads"

# Session cookie Secure flag. Behind HTTPS (NPM/reverse proxy) leave unset (=on).
# Set to "false" ONLY for plain-HTTP LAN access (e.g. http://<ip>:9960), else
# the browser drops the session cookie and login just bounces back.
# SESSION_COOKIE_SECURE="false"

# Google Maps browser key for the property location picker (search + click to
# fill lat/long). Read at runtime, so changing it needs only a `web` recreate,
# no rebuild. Enable "Maps JavaScript API" + "Places API" and restrict the key
# by HTTP referrer. Leave unset to hide the map (the manual lat/long + device-
# location button still work).
# GOOGLE_MAPS_API_KEY="AIza..."
